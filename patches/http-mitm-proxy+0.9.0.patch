+function closeWebSocketSafely(socket, code, message) {
+  try {
+    var valid = typeof code === 'number' &&
+      ((code === 1000) ||
+       (code >= 3000 && code <= 4999) ||
+       (code >= 1001 && code <= 1014 && code !== 1004 && code !== 1005 && code !== 1006));
+    if (valid) {
