+// 安全关闭 WebSocket：1005/1006/1015 等保留码不允许应用层显式发送，
+// 直接传给 ws.close() 会抛 "first argument must be a valid error code number" 并崩溃进程。
+// 合法范围：1000、3000-4999、以及部分 1001-1014（排除保留码）。不合法则无参关闭。
+function closeWebSocketSafely(socket, code, message) {
+  try {
+    var valid = typeof code === 'number' &&
+      ((code === 1000) ||
+       (code >= 3000 && code <= 4999) ||
+       (code >= 1001 && code <= 1014 && code !== 1004 && code !== 1005 && code !== 1006));
+    if (valid) {
+      socket.close(code, message);
+    } else {
+      socket.close();
+    }
+  } catch (e) {
+    // 兜底：即便如此仍异常（如底层 socket 已损坏），也不让它冒泡崩溃进程
+    try { socket.terminate(); } catch (e2) {}
+  }
+}
